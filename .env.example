# Backend / poller
ALECA_AGENT_URL=http://host.docker.internal:8788
ALECA_REDIS_URL=redis://redis:6379/0
ALECA_RABBITMQ_URL=amqp://aleca:aleca-local@rabbitmq:5672/
ALECA_CENTRIFUGO_API=http://centrifugo:8000/api
ALECA_CENTRIFUGO_API_KEY=local-dev-api-key-change-me
ALECA_CENTRIFUGO_TOKEN_HMAC_SECRET=local-dev-hmac-secret-change-me-do-not-use-in-prod-or-with-real-data
ALECA_DATA_DIR=/data
ALECA_TTL_SECONDS=60
ALECA_WFM_PLATFORM=pc
ALECA_LOG_LEVEL=INFO

# Host path to AlecaFrame's installation directory (containing cachedData/json/).
# Used by docker-compose to bind-mount AlecaFrame's static catalogues into the
# backend + poller containers. The loader reads set compositions, item names
# (NameResolver) and unique-name overrides from here.
#
# Windows (typical):  C:\Users\<you>\AppData\Local\AlecaFrame
# If unset, compose falls back to ./data (no AlecaFrame catalogues — only the
# hardcoded Kronen seed will show up under /me/sets-profit).
ALECA_DATA_HOME_HOST=

# Centrifugo (read by the container itself)
CENTRIFUGO_API_KEY=local-dev-api-key-change-me
CENTRIFUGO_TOKEN_HMAC_SECRET=local-dev-hmac-secret-change-me-do-not-use-in-prod-or-with-real-data

# Telegram bot for Void Fissure notifications (token from @BotFather).
# Leave empty to disable the Telegram subsystem (poller still runs; the
# Fissures page still shows live fissures, just no Telegram messages).
TG_API_KEY=
